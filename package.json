{
  "name": "@endge/nova-vue",
  "private": false,
  "version": "0.3.1",
  "type": "module",
  "module": "./dist/nova-vue.js",
  "types": "./dist/index.d.ts",
  "web-types": "./web-types.json",
  "nova": {
    "components": "./nova-components.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nova-vue.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "web-types.json",
    "nova-components.json"
  ],
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "dev": "vite build --watch",
    "dev:watch": "vite build --watch",
    "build": "vite build",
    "pretest": "pnpm --filter @endge/nova build && pnpm --filter @endge/nova-devtools build:runtime",
    "test": "vitest run --config vite.config.ts"
  },
  "dependencies": {
    "@endge/nova": "workspace:*",
    "@endge/nova-devtools": "workspace:*",
    "@endge/utils": "workspace:*",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "jsdom": "^26.1.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.0"
  }
}
